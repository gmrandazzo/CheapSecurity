{
  "camera": {
    "device": 0,
    "width": 2560,
    "height": 1440,
    "fps": 15,
    "night_mode": false,
    "night_mode_fps": 5,
    "night_mode_gain": 255,
    "night_mode_brightness": 200,
    "night_mode_contrast": 200
  },
  "motion": {
    "threshold": 25,
    "min_area": 2000,
    "blur_size": 21,
    "cooldown_seconds": 5,
    "scale": 0.25
  },
  "recording": {
    "dir": "./recordings",
    "max_duration_seconds": 60,
    "pre_buffer_seconds": 3,
    "codec": "MJPG",
    "extension": ".avi"
  },
  "notifications": {
    "enabled": false,
    "smtp": {
      "server": "smtp.gmail.com",
      "port": 465,
      "username": "you@gmail.com",
      "password": "your_gmail_app_password",
      "use_tls": true
    },
    "from": "you@gmail.com",
    "to": [
      "you@gmail.com"
    ],
    "subject": "CheapSecurity Motion Alert",
    "min_interval_minutes": 5
  },
  "telegram": {
    "enabled": false,
    "bot_token": "123456789:YOUR_BOT_TOKEN_HERE",
    "chat_id": "YOUR_CHAT_ID_HERE",
    "send_video": true,
    "min_interval_minutes": 5,
    "poll_commands": true
  },
  "web": {
    "host": "0.0.0.0",
    "port": 5000,
    "stream_scale": 0.5,
    "auth": {
      "enabled": false,
      "username": "admin",
      "password": "changeme"
    }
  },
  "storage": {
    "max_age_days": 3,
    "max_size_gb": 10,
    "cleanup_interval_minutes": 60,
    "delete_old_on_startup": false,
    "emergency_free_space_gb": 1.0,
    "emergency_delete_count": 4
  }
}
